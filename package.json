    "googleapis": "^173.0.0",
    "html-react-parser": "^6.1.3",
    "html-to-text": "^10.0.0",
    "microcms-js-sdk": "^3.4.0",
    "microcms-typescript": "^1.0.15",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-scroll": "^1.9.3",
    "react-textarea-autosize": "^8.5.9",
