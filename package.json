{
  "name": "hanabon-with-microcms",
  "version": "2.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write --ignore-path .gitignore .",
    "lint": "eslint src --fix",
    "lint:style": "stylelint \"**/*.{css,scss}\" --fix",
    "lint:all": "npm run lint && npm run lint:style",
    "check": "npm run format && npm run lint:all",
    "prepare": "node -e \"const fs=require('fs');const src='scripts/hooks/pre-commit';const dest='.git/hooks/pre-commit';fs.copyFileSync(src,dest);fs.chmodSync(dest,0o755);console.log('pre-commit hook installed');\""
  },
  "dependencies": {
    "@holiday-jp/holiday_jp": "^2.5.1",
    "@next/third-parties": "^16.2.9",
    "@vercel/speed-insights": "^2.0.0",
